      -- ターミナルモードでのキーマップ
      local opts = { noremap = true }
      vim.keymap.set('t', '<C-z>', '<C-z><C-n>', opts)  -- <Esc>の代わりに使用可能
      vim.keymap.set('t', '<C-w>', '<C-z><C-n><C-w>', opts)  -- ウィンドウ操作
    end,

  -- Treesitter: 高度なシンタックスハイライト
  {
    "nvim-treesitter/nvim-treesitter",
    lazy = false,
    build = ":TSUpdate",
    config = function()
      local treesitter = require("nvim-treesitter")

      treesitter.setup({
        install_dir = vim.fn.stdpath("data") .. "/site",
      })

      -- パーサーをインストール（VimEnterで確実に実行）
      vim.api.nvim_create_autocmd("VimEnter", {
        once = true,
        callback = function()
          local ensure_parsers = {
            "bash", "c", "cpp", "css", "html", "javascript", "json",
            "lua", "python", "rust", "typescript", "vim", "yaml",
            "go", "java", "sql", "markdown", "markdown_inline", "regex",
          }
          treesitter.install(ensure_parsers)
        end,
        desc = "Treesitterパーサーをインストール",
      })

      -- パーサーとハイライトクエリが両方有効な場合のみTreesitterを有効化
      -- (snapのビルトインパーサーとプラグインのクエリがバージョン不一致の場合にクラッシュを防ぐ)
      vim.api.nvim_create_autocmd("FileType", {
        callback = function(args)
          local lang = vim.treesitter.language.get_lang(vim.bo[args.buf].filetype)
          if not lang then
            return
          end

          -- パーサーを確認
          local ok, parser = pcall(vim.treesitter.get_parser, args.buf, lang)
          if not (ok and parser) then
            return
          end

          -- ハイライトクエリも有効か確認してからstart（クエリ不一致によるエラーを防ぐ）
          local query_ok = pcall(vim.treesitter.query.get, lang, "highlights")
          if not query_ok then
            return
          end

          pcall(vim.treesitter.start, args.buf)
          vim.bo[args.buf].indentexpr = "v:lua.require'nvim-treesitter'.indentexpr()"
        end,
        desc = "Treesitterのハイライトとインデントを有効化",
      })
    end,
  },

  -- Snacks: ユーティリティライブラリ（ダッシュボード対応）
  {
    "folke/snacks.nvim",
    priority = 1000,
    lazy = false,
    config = function()
      local Snacks = require("snacks")

      Snacks.setup({
        bigfile = { enabled = true },
        dashboard = {
          enabled = true,
          preset = {
            header = [[
 ███╗   ██╗███████╗ ██████╗ ██╗   ██╗██╗███╗   ███╗
 ████╗  ██║██╔════╝██╔═══██╗██║   ██║██║████╗ ████║
 ██╔██╗ ██║█████╗  ██║   ██║██║   ██║██║██╔████╔██║
 ██║╚██╗██║██╔══╝  ██║   ██║╚██╗ ██╔╝██║██║╚██╔╝██║
 ██║ ╚████║███████╗╚██████╔╝ ╚████╔╝ ██║██║ ╚═╝ ██║
 ╚═╝  ╚═══╝╚══════╝ ╚═════╝   ╚═══╝  ╚═╝╚═╝     ╚═╝
            ]],
            keys = {
              { icon = "󰘔 ", key = "n", desc = "New File", action = ":ene | startinsert" },
              { icon = "󰔟 ", key = "r", desc = "Recent Files", action = ":lua Snacks.dashboard.pick('oldfiles')" },
              { icon = "󰈙 ", key = "f", desc = "Find File", action = ":lua Snacks.dashboard.pick('files')" },
              { icon = "󰊄 ", key = "g", desc = "Find Text", action = ":lua Snacks.dashboard.pick('live_grep')" },
              { icon = "󰒓 ", key = "c", desc = "Config", action = ":e $MYVIMRC" },
              { icon = "󱂬 ", key = "s", desc = "Restore Session", section = "session" },
              { icon = "󰒲 ", key = "l", desc = "Lazy", action = ":Lazy", enabled = package.loaded.lazy ~= nil },
              { icon = "󰗼 ", key = "q", desc = "Quit", action = ":qa" },
            },
          },
          sections = {
            { section = "header" },
            { section = "keys", gap = 1, padding = 1 },
            { section = "startup" },
          },
        },
        indent = { enabled = true },
        input = { enabled = true },
        notifier = { enabled = true },
        quickfile = { enabled = true },
        scroll = { enabled = true },
        statuscolumn = { enabled = false },
        words = { enabled = true },
      })
    end,
  },

  -- mason.nvim: LSPサーバーのインストール管理
  {
    'williamboman/mason.nvim',
    build = ':MasonUpdate',
    opts = {},
  },

  -- nvim-lspconfig + mason-lspconfig: LSPクライアント設定
  {
    'neovim/nvim-lspconfig',
    dependencies = {
      'williamboman/mason.nvim',
      'williamboman/mason-lspconfig.nvim',
    },
    config = function()
      local lspconfig = require('lspconfig')

      local on_attach = function(_, bufnr)
        local opts = { buffer = bufnr, silent = true }
        vim.keymap.set('n', 'gd', vim.lsp.buf.definition, vim.tbl_extend('force', opts, { desc = '定義へジャンプ' }))
        vim.keymap.set('n', 'gD', vim.lsp.buf.declaration, vim.tbl_extend('force', opts, { desc = '宣言へジャンプ' }))
        vim.keymap.set('n', 'gr', vim.lsp.buf.references, vim.tbl_extend('force', opts, { desc = '参照一覧' }))
        vim.keymap.set('n', 'gi', vim.lsp.buf.implementation, vim.tbl_extend('force', opts, { desc = '実装へジャンプ' }))
        vim.keymap.set('n', 'K', vim.lsp.buf.hover, vim.tbl_extend('force', opts, { desc = 'ホバー情報' }))
        vim.keymap.set('n', '<leader>rn', vim.lsp.buf.rename, vim.tbl_extend('force', opts, { desc = 'リネーム' }))
        vim.keymap.set('n', '<leader>ca', vim.lsp.buf.code_action, vim.tbl_extend('force', opts, { desc = 'コードアクション' }))
        vim.keymap.set('n', '[d', vim.diagnostic.goto_prev, vim.tbl_extend('force', opts, { desc = '前の診断' }))
        vim.keymap.set('n', ']d', vim.diagnostic.goto_next, vim.tbl_extend('force', opts, { desc = '次の診断' }))
      end

      -- MasonでインストールしたLSPサーバーを自動セットアップ
      require('mason-lspconfig').setup({
        ensure_installed = {
          'pyright',       -- Python
          'rust_analyzer', -- Rust
          'lua_ls',        -- Lua
          'gopls',         -- Go
          'clangd',        -- C / C++
          'ts_ls',         -- TypeScript / JavaScript
          'jdtls',         -- Java
        },
        handlers = {
          -- デフォルトハンドラー（全サーバー共通）
          function(server_name)
            lspconfig[server_name].setup({ on_attach = on_attach })
          end,

          -- lua_ls: vim グローバル変数の警告を抑制
          ['lua_ls'] = function()
            lspconfig.lua_ls.setup({
              on_attach = on_attach,
              settings = {
                Lua = {
                  diagnostics = { globals = { 'vim' } },
                  workspace = {
                    library = vim.api.nvim_get_runtime_file('', true),
                    checkThirdParty = false,
                  },
                },
              },
            })
          end,

          -- jdtls: プロジェクトごとのワークスペースディレクトリを指定
          ['jdtls'] = function()
            lspconfig.jdtls.setup({
              on_attach = on_attach,
              cmd = {
                'jdtls',
                '-data',
                vim.fn.stdpath('data') .. '/jdtls-workspace/' ..
                  vim.fn.fnamemodify(vim.fn.getcwd(), ':t'),
              },
            })
          end,
        },
      })
    end,
  },

  -- flash.nvim: f/F/t/T モーションを複数行に対応
  {
    'folke/flash.nvim',
    event = 'VeryLazy',
    opts = {
      label = {
        alphabet = '1234567890',
        uppercase = false,
      },
      modes = {
        char = {
          enabled = true,
          jump_labels = false, -- f/t はラベルなしで最初の候補へ直接ジャンプ（カウント対応: 3f"）
          highlight = {
            backdrop = false,
            matches = false,  -- 候補ハイライトを無効
            groups = { match = 'Normal', current = 'Normal' }, -- ハイライトグループを無色に
          },
        },
        search = {
          label = { alphabet = '1234567890' }, -- gs 検索でも数字ラベルを使用
        },
      },
    },
    keys = {
      -- enter: 数字ラベルを表示して任意の位置へジャンプ（文字を入力後、数字で選択）
      { '<BS>', function() require('flash').jump({ label = { alphabet = '1234567890' } }) end, mode = { 'n', 'x', 'o' }, desc = '番号ラベルでフラッシュジャンプ' },
    },
  },

  -- mini.ai: vi"/va" 等のテキストオブジェクトを複数行に対応
  {
    'echasnovski/mini.ai',
    version = '*',
    event = 'VeryLazy',
    opts = {},
  },

  -- Comment.nvim: gcc/gc でコメントアウト・アンコメント
  {
    'numToStr/Comment.nvim',
    keys = { 'gc', 'gcc', { 'gc', mode = 'x' } },
    opts = {},
  },

  -- vim-sandwich: sa/sd/sr でテキストの囲みを追加・削除・置換
  {
    'machakann/vim-sandwich',
    keys = {
      { 'sa', mode = { 'n', 'x' } },
      { 'sd', mode = { 'n', 'x' } },
      { 'sr', mode = { 'n', 'x' } },
      { 'sdb' },
      { 'srb' },
    },
  },

  -- which-key.nvim: キーマップのポップアップヒント
  {
    'folke/which-key.nvim',
    event = 'VeryLazy',
    opts = {},
  },

  -- nvim-scrollbar: スクロールバーを表示
  {
    'petertriho/nvim-scrollbar',
    event = { 'BufReadPre', 'BufNewFile' },
    opts = {},
  },

  -- noice.nvim: コマンドライン・通知UIを改善
  {
    'folke/noice.nvim',
    event = 'VeryLazy',
    dependencies = {
      'MunifTanjim/nui.nvim',
      'rcarriga/nvim-notify',
    },
    config = function()
      -- パーサーが存在し、かつハイライトクエリが有効な場合のみlangを使う
      -- (snapのvimパーサーとプラグインのクエリがバージョン不一致の場合にクラッシュを防ぐ)
      local function has_parser(lang)
        if not pcall(vim.treesitter.language.add, lang) then return false end
        return pcall(vim.treesitter.query.get, lang, "highlights")
      end
      require("noice").setup({
        cmdline = {
          format = {
            cmdline     = { lang = has_parser("vim")   and "vim"       or false },
            search_down = { lang = has_parser("regex") and "regex"     or false },
            search_up   = { lang = has_parser("regex") and "regex"     or false },
            filter      = { lang = has_parser("bash")  and "bash"      or false },
            lua         = { lang = has_parser("lua")   and "lua"       or false },
            calculator  = { lang = has_parser("vim")   and "vimnormal" or false },
          },
        },
      })
    end,
  },

  -- treesj: コードブロックの分割・結合
  {
    'Wansmer/treesj',
    dependencies = { 'nvim-treesitter/nvim-treesitter' },
    keys = { { '<leader>m', desc = 'コードブロックを分割/結合' } },
    opts = {},
  },

  -- dial.nvim: インクリメント・デクリメントを強化
  {
    'monaqa/dial.nvim',
    keys = {
      { '<C-a>', mode = { 'n', 'v' } },
      { '<C-x>', mode = { 'n', 'v' } },
    },
    config = function()
      local augend = require('dial.augend')
      require('dial.config').augends:register_group({
        default = {
          augend.integer.alias.decimal,
          augend.integer.alias.hex,
          augend.date.alias['%Y/%m/%d'],
          augend.constant.alias.bool,
        },
      })
      local map = require('dial.map')
      vim.keymap.set({ 'n', 'v' }, '<C-a>', map.inc_normal(),  { desc = 'インクリメント' })
      vim.keymap.set({ 'n', 'v' }, '<C-x>', map.dec_normal(),  { desc = 'デクリメント' })
    end,
  },

  -- gitsigns.nvim: Gitの変更をサインカラムに表示
  {
    'lewis6991/gitsigns.nvim',
    event = { 'BufReadPre', 'BufNewFile' },
    opts = {
      signs = {
        add          = { text = '│' },
        change       = { text = '│' },
        delete       = { text = '_' },
        topdelete    = { text = '‾' },
        changedelete = { text = '~' },
      },
      on_attach = function(bufnr)
        local gs = package.loaded.gitsigns
        local opts = { buffer = bufnr, silent = true }
        vim.keymap.set('n', '<leader>gN', gs.next_hunk,   vim.tbl_extend('force', opts, { desc = '次の変更へ' }))
        vim.keymap.set('n', '<leader>gP', gs.prev_hunk,   vim.tbl_extend('force', opts, { desc = '前の変更へ' }))
        vim.keymap.set('n', '<leader>ghs', gs.stage_hunk,   vim.tbl_extend('force', opts, { desc = 'hunkをステージ' }))
        vim.keymap.set('n', '<leader>ghr', gs.reset_hunk,   vim.tbl_extend('force', opts, { desc = 'hunkをリセット' }))
        vim.keymap.set('n', '<leader>ghp', gs.preview_hunk, vim.tbl_extend('force', opts, { desc = 'hunkをプレビュー' }))        vim.keymap.set('n', '<leader>ghb', gs.blame_line,   vim.tbl_extend('force', opts, { desc = '行のblame' }))
      end,
    },
  },

  -- diffview.nvim: Gitの差分をビジュアルに表示
  {
    'sindrets/diffview.nvim',
    dependencies = { 'nvim-lua/plenary.nvim' },
    cmd = { 'DiffviewOpen', 'DiffviewClose', 'DiffviewToggleFiles', 'DiffviewFileHistory' },
    keys = {
      { '<leader>gdf', '<cmd>DiffviewOpen<cr>',                desc = 'Diff: 作業ツリーを開く' },
      { '<leader>gdd', '<cmd>DiffviewClose<cr>',               desc = 'Diff: 閉じる' },
      { '<leader>gdt', '<cmd>DiffviewToggleFiles<cr>',         desc = 'Diff: ファイルパネルを切り替え' },
    },
    opts = {},
  },

  -- project.nvim: プロジェクト管理（自動cd）
  {
    'ahmedkhalf/project.nvim',
    event = 'VeryLazy',
    config = function()
      require('project_nvim').setup({})
      require('telescope').load_extension('projects')
      vim.keymap.set('n', '<leader>fp', '<cmd>Telescope projects<cr>', { desc = 'プロジェクトを検索' })
    end,
